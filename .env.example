# Required Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Existing application authentication and domain routing
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_LOGIN_OTP_SECRET=replace-or-leave-unset-to-use-jwt-secret
ADMIN_SUBDOMAIN=admin-dm.erniecodev.win
NEXT_PUBLIC_APP_DOMAIN=public-dm.erniecodev.win

# Existing email delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM="D&M Travellers Inn <no-reply@example.com>"

# Existing PayMongo features
PAYMONGO_SECRET_KEY=sk_live_or_test_key
PAYMONGO_WEBHOOK_SECRET=replace-with-webhook-secret
PAYMONGO_API_BASE_URL=https://api.paymongo.com/v1
PAYMONGO_QRPH_EXPIRY_SECONDS=1800
PAYMONGO_TREASURY_WALLET_ID=
PAYMONGO_TREASURY_CALLBACK_SECRET=

# Existing protected server operations
CRON_SECRET=
TREASURY_DESTINATION_SECRET=
CASH_ACCOUNT_SECRET=

# Only required when running the optional Compose cloudflared profile
CLOUDFLARE_TUNNEL_TOKEN=
