# ===========================================
# D&M Travelers Inn – Local Environment
# Add your real values here. Do not commit.
# ===========================================

# --- DATABASE (Supabase) ---
# From Supabase: Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=
# From Supabase: Project Settings → API → service_role key (secret)
SUPABASE_SERVICE_ROLE_KEY=

# --- AUTHENTICATION ---
# Any long random string (e.g. openssl rand -base64 32)
JWT_SECRET=
# Optional: for extra admin API protection
ADMIN_API_SECRET=

# --- FRONTEND ---
# For local dev use http://localhost:3000
NEXT_PUBLIC_API_URL=
# Vite reads only VITE_* — API server runs on port 5471 (npm run api)
VITE_API_URL=

# --- EMAIL (SMTP) ---
# e.g. smtp.gmail.com, smtp.sendgrid.net, or your provider
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
# Sender address shown to guests
SMTP_FROM=

# --- PAYMENTS ---
# Stripe: Dashboard → Developers → API keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# PayPal: Developer dashboard
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# GCash / PayMongo or provider
GCASH_API_KEY=

ADMIN_EMAIL=
ADMIN_PASSWORD=