# --- DATABASE (Supabase) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- AUTHENTICATION ---
JWT_SECRET=
ADMIN_API_SECRET=

# --- FRONTEND (Vite exposes only VITE_* to the client) ---
# Base URL of the API server. This project uses 2 ports: frontend 4242, server 5471.
VITE_API_URL=http://localhost:5471
# Optional: override API server port (default 5471)
# API_PORT=5471

# --- EMAIL (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=D&M Travelers Inn <noreply@example.com>

# --- PAYMENTS ---
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
GCASH_API_KEY=
